<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
	"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace = "com.example.demo.mapper.UserMapper"> <!--연결할mapper파일-->

	<select id="selectUserList" parameterType="hashmap" resultType="com.example.demo.model.User">
		SELECT *
		FROM TBL_USER
	</select>
	
	<!--아이디중복체크-->
	<select id="selectUser" parameterType="hashmap" resultType="com.example.demo.model.User">
		SELECT * 
		FROM TBL_USER
		WHERE USERID = #{userId}
	</select>
	
	<!--첨부파일-->
