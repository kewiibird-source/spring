	</insert>
	<select id="selectUser" parameterType="hashmap" resultType="com.example.demo.model.User">
		SELECT * 
		FROM TBL_USER
		WHERE USERID = #{userId}
	</select>-->
	
	<!--회원가입-->
	<insert id="insertUser" parameterType="hashmap">
		INSERT INTO TBL_USER(USERID, PWD, USERNAME) 
		VALUES(#{userId}, #{pwd}, #{userName}) 
	</insert>
	
	<delete id="deleteUser" parameterType="hashmap">
		DELETE FROM
		TBL_USER WHERE USERID = #{userId} <!--프론트에서 받을 id의 키값-->
	</delete>
</mapper>